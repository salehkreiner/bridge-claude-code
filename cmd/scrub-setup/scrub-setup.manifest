<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Application manifest for scrub-setup.exe.

  This exists for ONE reason: scrub-setup runs as a normal, unprivileged user. By
  declaring requestedExecutionLevel="asInvoker" we (1) state that truth, and
  (2) disable Windows' UAC "Installer Detection" heuristic, which would otherwise
  see the word "setup" in the file name and force an elevation prompt before the
  process even starts. asInvoker means: run with exactly the rights of whoever
  launched it — no elevation, no prompt.

  uiAccess="false" is the normal value (no special UI automation privileges).
-->
<assembly xmlns="urn:schemas-microsoft-com:asm.v1" manifestVersion="1.0">
  <trustInfo xmlns="urn:schemas-microsoft-com:asm.v3">
    <security>
      <requestedPrivileges>
        <requestedExecutionLevel level="asInvoker" uiAccess="false"/>
      </requestedPrivileges>
    </security>
  </trustInfo>
  <compatibility xmlns="urn:schemas-microsoft-com:compatibility.v1">
    <application>
      <!-- Declare compatibility with Windows 7 through 11 so the OS does not
           apply legacy compatibility shims. -->
      <supportedOS Id="{8e0f7a12-bfb3-4fe8-b9a5-48fd50a15a9a}"/> <!-- Windows 10/11 -->
      <supportedOS Id="{1f676c76-80e1-4239-95bb-83d0f6d0da78}"/> <!-- Windows 8.1 -->
      <supportedOS Id="{4a2f28e3-53b9-4441-ba9c-d69d4a4a6e38}"/> <!-- Windows 8 -->
      <supportedOS Id="{35138b9a-5d96-4fbd-8e2d-a2440225f93a}"/> <!-- Windows 7 -->
    </application>
  </compatibility>
</assembly>
